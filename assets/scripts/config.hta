<!DOCTYPE html>
<html>
	<head>
		<meta http-equiv='X-UA-Compatible' content='IE=edge'>
		<meta name='viewport' content='width=device-width, initial-scale=1.0'>

		<title>RainJIT Configuration Tool</title>
		<hta:application
			id="FoldersEnvApp"
			icon="app.ico"
			applicationname="FoldersEnvHTA"
			border="thin"
			caption="yes"
			sysmenu="yes"
			showintaskbar="yes"
			singleinstance="yes"
			windowstate="normal"
			maximizebutton="no"
			minimizebutton="yes"
			width="740"
		/>

		<style>
			* {
				-ms-user-select: none;
				cursor: default;
			}

			/* http://help.dottoro.com/lcjpgkes.php */
			/* CSS proprietário do Trident (IE5–IE8) */
			body.dark * {
				scrollbar-3dlight-color: #2c2c2c;
				scrollbar-arrow-color: #cfcfcf;
				scrollbar-darkshadow-color: #000000;
				scrollbar-face-color: #3a3a3a;
				scrollbar-highlight-color: #5a5a5a;
				scrollbar-shadow-color: #1a1a1a;
				scrollbar-track-color: #1f1f1f;
			}

			button { cursor: pointer; }
			input[type="text"] {
				cursor: text;
				font-family: inherit;
				font-size: inherit;
				-ms-user-select: text;
			}


			html {
				position: fixed;
			}

			html, body {
				font-family: 'Segoe UI', Arial;
				letter-spacing: 0.5px;
				background-color: #f4f6f8;
				margin: 0;
				border: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow-x: auto;
			}
			body.dark {
				background-color: #212121;
				color: #fff;
			}

			h2 {
				margin-top: 0;
				color: #2c3e50;
				font-size: 17px;
			}
			body.dark h2 { color: #fff; }

			.section {
				padding: 10px;
			}

			.field {
				margin-top: 10px;
			}

			.field label {
				display: inline-block;
			}

			.field input[type="text"] {
				width: 340px;
			}

			.field button {
				width: 30px;
			}

			label {
				width: 200px;
			}

			input[type="text"] {
				flex: 1;
				padding: 5px;
				border: 1px solid #ccc;
				border-radius: 3px;
			}

			button {
				border: none;
				border-radius: 4px;
				background-color: #3498db;
				color: white;
				cursor: pointer;
				font-weight: bold;
			}

			button.browse {
				width: 30px;
				margin-left: 5px;
				font-size: 15px;
				height: 100%;
			}

			button.browse:hover {
				background-color: #2980b9;
			}

			textarea {
				width: calc( 100% - 5px );
				height: 150px;
				margin-top: 10px;
				resize: none;
				border-radius: 4px;
				border: 1px solid #ccc;
				font-family: Consolas, monospace;
			}

			body.dark textarea,
			body.dark input[type="text"] {
				background-color: rgba(0,0,0,.1);
				border-color: #161616;
				color: #fff;
			}
		</style>


		<script language="javascript">
			var fso = new ActiveXObject( 'Scripting.FileSystemObject' )
			var shell = new ActiveXObject( 'Shell.Application' )
			var wshell = new ActiveXObject( 'WScript.Shell' )

			var scriptDir = decodeURIComponent(
				window.location.href
				.replace(/^file:[\/]+/i, '' )
				.replace( /(\/[^\/]*\.hta)$/i, '' )
			)

			function isDarkMode() {
				try {
					var value = wshell.RegRead(
						'HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize\\AppsUseLightTheme'
					);
					return value === 0;
				}
				// Key not found (Windows < 10)
				catch (e) {
					return false;
				}
			}

			function browseFolder(targetId) {
				var folder = shell.BrowseForFolder(0, "Select a folder", 0);

				if (!folder)
					return;

				var ele = document.getElementById(targetId);
				var key = ele.getAttribute('env');
				var path = folder.Self.Path;

				ele.value = path;

				updateEnvVar(key, path);
				saveEnvFile();

				envContent.value = ENV.__inner;
			}

			function browseFile(targetId) {
				try {
					var dialog = shell.BrowseForFolder(
						0,
						"Select .env file",
						0x4000, // BIF_BROWSEINCLUDEFILES
						"*.env"
					);

					if (dialog && dialog.Items().Item()) {
						var file = dialog.Items().Item();
						document.getElementById(targetId).value = file.Path;
					}
				} catch (e) {
					alert("Error: " + e.message);
				}
			}

			function readEnvFile(filePath) {
				if (!filePath)
					return alert('Please select a .env file.');

				try {
					if ( ! fso.FileExists( filePath ))
						return alert('.env file not found.' )

					var file = fso.OpenTextFile(filePath, 1);
					var envObject = { __inner: '' };

					while (!file.AtEndOfStream) {
						var line = file.ReadLine().trim();

						// Ignora comentários e linhas vazias
						if (line === '' || line.match( /^\s*#/ ))
							continue;

						// Divide chave e valor
						envObject.__inner += line + '\n'
						var parts = line.split('=');

						if (parts.length >= 2) {
							var key = parts[0].trim();
							var value = parts.slice(1).join('=').trim(); // Junta caso tenha = no valor

							// Remove aspas
							// if ((value.startsWith('"') && value.endsWith('"')) ||
							// 	(value.startsWith("'") && value.endsWith("'"))) {
							// 	value = value.substring(1, value.length - 1);
							// }

							envObject[key] = value;
						} else if (parts.length === 1) {
							// Chave sem valor
							envObject[parts[0].trim()] = '';
						}
					}

					file.Close();
					return envObject;
				}
				catch (e) {
					alert('Error reading .env file:\n' + e.message);
					return null;
				}
			}

			function saveEnvFile() {
				var path = scriptDir + '/.env';

				try {
					var file = fso.OpenTextFile(path, 2, true);
					file.Write(ENV.__inner.replace(/\n$/, ''));
					file.Close();
				}
				catch (e) {
					alert('Error saving .env file:\n' + e.message);
				}
			}

			function updateEnvVar(key, value) {
				var escapedKey = key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
				var regex = new RegExp('^\\s*' + escapedKey + '\\s*=.*$', 'm');

				if (ENV.__inner.match(regex)) {
					// Substitui linha existente
					ENV.__inner = ENV.__inner.replace(regex, key + '=' + value);
				} else {
					// Adiciona nova linha
					if (ENV.__inner && !ENV.__inner.endsWith('\n'))
						ENV.__inner += '\n';

					ENV.__inner += key + '=' + value + '\n';
				}

				ENV[key] = value;
			}


			window.onload = function() {
				if ( isDarkMode())
					document.body.className = "dark"

				window.resizeTo(650, 470)

				window.ENV = readEnvFile( scriptDir + '/.env' )
				window.envContent.value = ENV.__inner
				window.folder1.value = ENV.RAINMETER_PATH || ''
				window.folder2.value = ENV.PLUGIN_PATH || ''
				window.folder3.value = ENV.SKINS_PATH || ''
			};

			// Disable the zoon page
			window.addEventListener( 'wheel', function( event ) {
				if ( event.ctrlKey )
					event.preventDefault();
			});
		</script>
	</head>

	<body>

		<div class="section">
			<h2>Folder Paths</h2>

			<div class="field">
				<label>Rainmeter Folder</label>
				<input type="text" id="folder1" env="RAINMETER_PATH">
				<button class="browse" onclick="browseFolder('folder1')">...</button>
			</div>

			<div class="field">
				<label>Rainmeter Plugin Folder</label>
				<input type="text" id="folder2" env="PLUGIN_PATH">
				<button class="browse" onclick="browseFolder('folder2')">...</button>
			</div>

			<div class="field">
				<label>Rainmeter Skin Folder</label>
				<input type="text" id="folder3" env="SKINS_PATH">
				<button class="browse" onclick="browseFolder('folder3')">...</button>
			</div>
		</div>

		<div class="section" style="margin-top: 30px;">
			<h2>.env File</h2>
			<textarea id="envContent" readonly></textarea>
		</div>

	</body>
</html>
