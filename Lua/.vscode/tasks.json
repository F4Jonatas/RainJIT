{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Copy RainJIT Modules → Rainmeter @Vault",
			"type": "shell",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\..\\assets\\scripts\\copy-folder.ps1",
				"-Type",
				"Rain2Modules"
			],
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"icon": {
				"id": "file-symlink-directory",
				"color": "terminal.ansiBlue"
			},
			"problemMatcher": [
				{
					"owner": "lua",
					"pattern": [
						{
							"regexp": "^(?:.*):(.*):([0-9]+):(([0-9]+):)? (.*)",
							"file": 1,
							"line": 2,
							"column": 3,
							"message": 5
						}
					],
					"severity": "error"
				}
			]
		}
	]
}
